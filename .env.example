# 高德地图 Web 服务 API Key（必填）
# 申请地址: https://console.amap.com/dev/key/app
AMAP_API_KEY=你的高德Web服务APIKey

# 高德地图 JS API Key + 安全密钥（用于前端地图展示）
# 在 https://console.amap.com/dev/key/app 申请 JS API Key
AMAP_JS_API_KEY=
AMAP_JS_SECURITY_CODE=

# 飞书机器人 Webhook URL（选填）
# 在飞书群中添加自定义机器人获取
FEISHU_WEBHOOK=

# 服务端口
PORT=8000